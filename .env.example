# Stream source: "0" for webcam, or full RTSP URL
STREAM_SOURCE=0
STREAM_FPS_LIMIT=10

# YOLOv8 face model
YOLO_MODEL_PATH=yolov8n-face.pt
DETECTION_CONFIDENCE=0.5

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=face_events
RABBITMQ_ROUTING_KEY=face.detected

# App
APP_NAME=face-recognition-edge
DEBUG=false
